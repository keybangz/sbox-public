# Ignore all files by default
*
!*/
.opencode/**
.beaconignore

# Git
!.gitignore
!.gitattributes
!.github/workflows/**

# Source files
!*.sln
!*.csproj
!*.cs
!*.razor


# Sandbox source files
!*.scene
!*.prefab
!*.clothing
!*.sound
!*.decal
!*.sndscape
!*.surface
!*.vtex

# Shader files
!*.shader
!*.fxc
!*.hlsl
!*.hlsli

# Text files
!*.txt
!*.md
!*.ini
!*.cfg
!*.json
!*.css
!.editorconfig
!.yaml
!.yml

# Script files
!*.bat
!*.sh
!*.py

# Linux native client files
!linux/**
!*.c

# Only allow .so files in the linux/ directory (wrapper libs)
# Native engine binaries should NOT be committed
/game/bin/**/*.so
/game/*.so
/engine/Tools/**/publish*/*.so
/engine/Tools/**/bin_standalone/*.so

#
# Some junk
#

# Local input files
*#local.json

game/config/input/common.json
*.codegen
engine/CodeGen.deps.json
engine/CodeGen.runtimeconfig.json
.generated
game/core/shadercache/vulkan/shaders.cache
engine/Sandbox.Compiling/EmbeddedRefs/*.xml
game/*.xml
engine/TestResults/

/engine/**/Interop.*.cs

#
# Visual Studio
#
.vs/
.intermediate/

# addon debris
/game/**/.sbox/*
/game/**/*.sln
/game/**/*.csproj
/game/**/obj
/game/**/launchSettings.json

#
# Game debris
#
/game/.source2
/game/_toolsettings

# Transients (compiled assets)
/game/**/Transients/
/game/bin/**/*.pdb
/game/bin/**/*.dll
/game/bin/**/*.xml
/game/bin/**/*.json
/game/bin/win64/logs
/game/config/**/*.json
/game/config/**/*.json.backup
/game/core/cfg/*.vcfg
/game/core/cfg/video.txt
/game/core/cfg/video_tools.txt
/game/data
/game/download
/game/download_test
/game/logs
/game/screenshots
/game/tools
/game/aftermath_dumps
/game/gamecache
linux/docs/reverse_engineering/ida_output/resource_compiler_dll_info.txt
linux/docs/reverse_engineering/scripts/resource_compiler_dll_info.txt
