{
  "embedding": {
    "api_base": "local",
    "model": "all-MiniLM-L6-v2",
    "dimensions": 384,
    "batch_size": 32,
    "context_limit": 256,
    "query_prefix": "",
    "api_key_env": "",
    "enabled": true
  },
  "chunking": {
    "strategy": "hybrid",
    "max_tokens": 512,
    "overlap_tokens": 32
  },
  "indexing": {
    "include": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.py",
      "**/*.go",
      "**/*.rs",
      "**/*.java",
      "**/*.rb",
      "**/*.php",
      "**/*.sql",
      "**/*.md"
    ],
    "exclude": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".next/**",
      "*.lock",
      "*.min.js",
      ".git/**",
      ".env*"
    ],
    "max_file_size_kb": 500,
    "auto_index": true,
    "max_files": 10000,
    "concurrency": 4
  },
  "search": {
    "top_k": 10,
    "similarity_threshold": 0.35,
    "hybrid": {
      "enabled": true,
      "weight_vector": 0.4,
      "weight_bm25": 0.3,
      "weight_rrf": 0.3,
      "doc_penalty": 0.5,
      "identifier_boost": 1.5,
      "debug": false
    }
  },
  "storage": {
    "path": ".opencode/.beacon"
  }
}