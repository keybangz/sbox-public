@using Sandbox;
@using Sandbox.UI;
@using MenuProject.UI;
@inherits Panel

<root class="content-block-header">
    <row>
        <a href=@url>
            <label class="heading icon">@Group.Icon</label>
            <label class="heading">@Group.Title</label>
            <label class="heading icon chevron">chevron_right</label>
        </a>
    </row>
</root>

@code
{
    [Parameter]
    public Package.ListResult.Grouping Group { get; set; }

    string url => $"/games/group?Query={Group.QueryString}&title={Group.Title}&icon={Group.Icon}";
}
