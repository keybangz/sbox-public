@using MenuProject
@using MenuProject.MenuUI.Components.Notifications
@using Sandbox.UI;
@using Sandbox.UI.Navigation;
@using Sandbox;
@using System;
@namespace Sandbox.UI
@inherits Panel

<root class="@ComputedClass">
    <div class="inner">

        <div class="links">
            <Logo Href="/home" />

            <separator class="vertical" />

            <Button Href="/hub" Icon="hub">#menu.hub</Button>

            <Button href="/games/dash" icon="sports_esports" Text="#menu.games">
                <HoverMenu>
                    <Button Href="/games/dash" icon="diamond">Discover</Button>
                    <Button Href="/games/group?Query=type:game sort:favourite&title=Favourite Games&Icon=💖" icon="favorite">Favourites</Button>
                    <Button Href="/games/all" icon="manage_search">Search</Button>
                </HoverMenu>
            </Button>
            <Button Href="/maps/all" Icon="map">#menu.maps</Button>
            <Button Href="/multiplayer" Icon="view_list">#menu.multiplayer</Button>
        </div>
        
        <div class="right">
            <Button @onmouseup=@OpenAvatarScene Icon="emoji_people">#menu.avatar</Button>

            <span class="store-wrapper">
                <FeaturedStoreItem />
                <Button Href="/itemstore" class="unread" Icon="store">#menu.store</Button>
            </span>

            <separator class="vertical" />

            <NotificationButton />
            <Button @onmouseup=@Settings Icon="settings"></Button>

            <Button onmouseup="@Quit" class="close" Icon="power_settings_new"></Button>
        </div>

    </div>

    <MainSearchBar />
</root>

@code {
    public string ComputedClass => (this.GetNavigator()?.CurrentUrlMatches("/home") ?? false) ? "clear" : "";

    void Settings()
    {
        Game.Overlay.ShowSettingsModal();
    }

    void Quit()
    {
        ConsoleSystem.Run("quit");
    }

    void OpenAvatarScene()
    {
        LogAvatarTransition("[Navbar] OpenAvatarScene() START");

        var options = new SceneLoadOptions();
		options.ShowLoadingScreen = true;

		// Use minimal avatar scene for debugging if SBOX_MINIMAL_AVATAR=1
		var useMinimal = System.Environment.GetEnvironmentVariable("SBOX_MINIMAL_AVATAR") == "1";
		var scenePath = useMinimal ? "/scenes/avatar_minimal.scene" : "/scenes/avatar.scene";

		if (useMinimal)
			Log.Info("[Avatar] Using minimal avatar scene for debugging");

		LogAvatarTransition($"[Navbar] Loading scene: {scenePath}");
		LogAvatarTransition($"[Navbar] Current ActiveScene: {Game.ActiveScene?.Name ?? "null"}");

		options.SetScene(scenePath);

        Game.ActiveScene.Load(options);

        LogAvatarTransition("[Navbar] OpenAvatarScene() - Load() called, returning");
    }

    private static void LogAvatarTransition(string message)
    {
        var timestamp = DateTime.Now.ToString("HH:mm:ss.fff");
        var logLine = $"[AVATAR {timestamp}] {message}";
		Log.Info(logLine);
        try
        {
        }
        catch { }
    }

    protected override int BuildHash() => HashCode.Combine(ComputedClass);
}
