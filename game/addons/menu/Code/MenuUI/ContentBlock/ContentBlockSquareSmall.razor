@using Sandbox;
@using Sandbox.UI;
@using MenuProject.UI;
@inherits Panel

<root class="cblock">
    <ContentBlockHeader Group="@Group"></ContentBlockHeader>
	<ContentBlockBody>
		<ChildContent>
			@foreach ( var package in Group.Packages )
			{
                <GameCard Size=@GameCard.SizeTypes.Small Package=@package></GameCard>
			}
		</ChildContent>
	</ContentBlockBody>
</root>

@code
{
    [Parameter]
    public Package.ListResult.Grouping Group { get; set; }
}
